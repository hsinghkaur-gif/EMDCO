@prefix : <http://www.example.org/emdco#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@base <http://www.example.org/emdco#> .

<http://www.example.org/emdco> rdf:type owl:Ontology ;
                                dc:creator "Harmanjeet Singh Kaur"@en ;
                                dc:description "This ontology models the EUDAMED catalogue including devices, manufacturers, identified risks, incidents and field safety corrective actions (FSCA)."@en ;
                                dc:title "European Medical Device Catalogue Ontology (EMDCO)"@en ;
                                rdfs:comment "Ontology for the European catalogue of high-risk medical devices under MDR (EU 2017/745) and IVDR (EU 2017/746)."@en ;
                                rdfs:label "European Medical Device Catalogue Ontology"@en ;
                                owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument1
swrl:argument1 rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument2
swrl:argument2 rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#body
swrl:body rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#classPredicate
swrl:classPredicate rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#head
swrl:head rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#propertyPredicate
swrl:propertyPredicate rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/emdco#addressesIncident
:addressesIncident rdf:type owl:ObjectProperty ;
                   rdfs:domain :FieldSafetyCorrectiveAction ;
                   rdfs:range :Incident ;
                   rdfs:comment "Relates a field safety corrective action to the incident that triggered it."@en ;
                   rdfs:label "addresses incident"@en .


###  http://www.example.org/emdco#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :Device ;
                   rdfs:comment "Relates a risk to the type of device it primarily affects."@en ;
                   rdfs:label "affects device type"@en .


###  http://www.example.org/emdco#associatedRisk
:associatedRisk rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Risk ;
                rdfs:comment "Relates an incident to the identified risk category according to IMDRF nomenclature."@en ;
                rdfs:label "associated risk"@en .


###  http://www.example.org/emdco#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Relates a device to its registered manufacturer in EUDAMED."@en ;
                 rdfs:label "has manufacturer"@en .


###  http://www.example.org/emdco#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Relates a device to its regulatory risk classification."@en ;
              rdfs:label "has risk class"@en .


###  http://www.example.org/emdco#involvedDevice
:involvedDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Device ;
                rdfs:comment "Relates an incident to the specific device involved in the event."@en ;
                rdfs:label "involved device"@en .


###  http://www.example.org/emdco#isSubclassifiedUnder
:isSubclassifiedUnder rdf:type owl:ObjectProperty ,
                               owl:TransitiveProperty ;
                      rdfs:domain :RiskClass ;
                      rdfs:range :RiskClass ;
                      rdfs:comment "Transitive property relating a risk class to a higher-level risk class in the MDR/IVDR classification hierarchy."@en ;
                      rdfs:label "is subclassified under"@en .


###  http://www.example.org/emdco#issuedBy
:issuedBy rdf:type owl:ObjectProperty ;
          rdfs:domain :FieldSafetyCorrectiveAction ;
          rdfs:range :Manufacturer ;
          rdfs:comment "Relates a field safety corrective action to the manufacturer who issued it."@en ;
          rdfs:label "issued by"@en .


###  http://www.example.org/emdco#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Relates an incident to the manufacturer who submitted the report to EUDAMED."@en ;
            rdfs:label "reported by"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/emdco#actionDate
:actionDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :FieldSafetyCorrectiveAction ;
            rdfs:range xsd:date ;
            rdfs:comment "The date on which the corrective action was initiated."@en ;
            rdfs:label "action date"@en .


###  http://www.example.org/emdco#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The national authorization number issued by the competent authority."@en ;
                     rdfs:label "authorization number"@en .


###  http://www.example.org/emdco#country
:country rdf:type owl:DatatypeProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range xsd:string ;
         rdfs:comment "The country where the manufacturer is legally registered."@en ;
         rdfs:label "country"@en .


###  http://www.example.org/emdco#countryReported
:countryReported rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The EU member state where the incident was reported."@en ;
                 rdfs:label "country reported"@en .


###  http://www.example.org/emdco#deviceID
:deviceID rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:string ;
          rdfs:comment "Unique identifier for the device in the EUDAMED catalogue."@en ;
          rdfs:label "device ID"@en .


###  http://www.example.org/emdco#deviceName
:deviceName rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "The commercial or trade name of the medical device."@en ;
            rdfs:label "device name"@en .


###  http://www.example.org/emdco#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ;
                 rdfs:domain :FieldSafetyCorrectiveAction ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "The number of devices covered by the field safety corrective action."@en ;
                 rdfs:label "devices affected"@en .


###  http://www.example.org/emdco#eudameSRN
:eudameSRN rdf:type owl:DatatypeProperty ;
           rdfs:domain :Manufacturer ;
           rdfs:range xsd:string ;
           rdfs:comment "Single Registration Number assigned by EUDAMED to the manufacturer."@en ;
           rdfs:label "EUDAMED SRN"@en .


###  http://www.example.org/emdco#eudamedFscaRef
:eudamedFscaRef rdf:type owl:DatatypeProperty ;
                rdfs:domain :FieldSafetyCorrectiveAction ;
                rdfs:range xsd:string ;
                rdfs:comment "The official EUDAMED reference number for the field safety corrective action."@en ;
                rdfs:label "EUDAMED FSCA reference"@en .


###  http://www.example.org/emdco#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The official EUDAMED reference number for the incident report."@en ;
                    rdfs:label "EUDAMED incident reference"@en .


###  http://www.example.org/emdco#fscaID
:fscaID rdf:type owl:DatatypeProperty ;
        rdfs:domain :FieldSafetyCorrectiveAction ;
        rdfs:range xsd:string ;
        rdfs:comment "Unique identifier for the field safety corrective action."@en ;
        rdfs:label "FSCA ID"@en .


###  http://www.example.org/emdco#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "The standardised IMDRF (International Medical Device Regulators Forum) nomenclature code for the risk."@en ;
           rdfs:label "IMDRF code"@en .


###  http://www.example.org/emdco#incidentID
:incidentID rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Unique identifier for the incident in EUDAMED."@en ;
            rdfs:label "incident ID"@en .


###  http://www.example.org/emdco#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The intended use of the device as declared by the manufacturer."@en ;
                 rdfs:label "intended purpose"@en .


###  http://www.example.org/emdco#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device operation depends on an external energy source."@en ;
          rdfs:label "is active"@en .


###  http://www.example.org/emdco#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Indicates whether the device is an in vitro diagnostic device regulated under IVDR."@en ;
       rdfs:label "is IVD"@en .


###  http://www.example.org/emdco#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is intended to be implanted in the human body."@en ;
               rdfs:label "is implantable"@en .


###  http://www.example.org/emdco#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device can be reused after appropriate reprocessing."@en ;
            rdfs:label "is reusable"@en .


###  http://www.example.org/emdco#manufacturerID
:manufacturerID rdf:type owl:DatatypeProperty ;
                rdfs:domain :Manufacturer ;
                rdfs:range xsd:string ;
                rdfs:comment "The unique manufacturer identifier in EUDAMED."@en ;
                rdfs:label "manufacturer ID"@en .


###  http://www.example.org/emdco#manufacturerName
:manufacturerName rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The registered legal name of the manufacturer."@en ;
                  rdfs:label "manufacturer name"@en .


###  http://www.example.org/emdco#outcome
:outcome rdf:type owl:DatatypeProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "The clinical outcome of the incident for the patient or user."@en ;
         rdfs:label "outcome"@en .


###  http://www.example.org/emdco#patientAge
:patientAge rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:integer ;
            rdfs:comment "Age of the patient involved in the incident at the time of the event."@en ;
            rdfs:label "patient age"@en .


###  http://www.example.org/emdco#probability
:probability rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "The estimated probability of occurrence of the risk: Low, Medium or High."@en ;
             rdfs:label "probability"@en .


###  http://www.example.org/emdco#regulatoryFramework
:regulatoryFramework rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Device ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The EU regulation applicable to the device: MDR or IVDR."@en ;
                     rdfs:label "regulatory framework"@en .


###  http://www.example.org/emdco#reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "The date on which the incident was officially reported to EUDAMED."@en ;
            rdfs:label "report date"@en .


###  http://www.example.org/emdco#riskName
:riskName rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "The descriptive name of the identified risk."@en ;
          rdfs:label "risk name"@en .


###  http://www.example.org/emdco#severity
:severity rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "The clinical severity of the risk: Critical, Serious, Moderate or Low."@en ;
          rdfs:label "severity"@en .


###  http://www.example.org/emdco#status
:status rdf:type owl:DatatypeProperty ;
        rdfs:domain :FieldSafetyCorrectiveAction ;
        rdfs:range xsd:string ;
        rdfs:comment "The current status of the corrective action: Open or Closed."@en ;
        rdfs:label "status"@en .


###  http://www.example.org/emdco#udiDI
:udiDI rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       rdfs:comment "Unique Device Identifier - Device Identifier as registered in EUDAMED."@en ;
       rdfs:label "UDI-DI"@en .


#################################################################
#    Classes
#################################################################

###  http://www.example.org/emdco#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :Device ;
              rdfs:comment "A medical device whose operation depends on a source of energy other than that generated by the human body or gravity."@en ;
              rdfs:label "Active Device"@en .


###  http://www.example.org/emdco#ActiveImplantDevice
:ActiveImplantDevice rdf:type owl:Class ;
                     rdfs:subClassOf :ActiveDevice ,
                                     :ImplantableDevice ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :isActive ;
                                       owl:hasValue "true"^^xsd:boolean
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :isImplantable ;
                                       owl:hasValue "true"^^xsd:boolean
                                     ] ;
                     rdfs:comment "A device that is both active and implantable, such as pacemakers or ventricular assist devices."@en ;
                     rdfs:label "Active Implant Device"@en .


###  http://www.example.org/emdco#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk from reagent or product contamination leading to systematic errors."@en ;
                   rdfs:label "Contamination Risk"@en .


###  http://www.example.org/emdco#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk from exploitable software vulnerabilities enabling unauthorised device access."@en ;
                   rdfs:label "Cybersecurity Risk"@en .


###  http://www.example.org/emdco#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf :MedicalEntity ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:minCardinality "1"^^xsd:nonNegativeInteger
                        ] ;
        rdfs:comment "A medical device as defined by MDR (EU 2017/745) or IVDR (EU 2017/746)."@en ;
        rdfs:label "Device"@en .


###  http://www.example.org/emdco#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk of diagnostic error including false positive or false negative results from IVD devices."@en ;
                rdfs:label "Diagnostic Risk"@en .


###  http://www.example.org/emdco#FieldSafetyCorrectiveAction
:FieldSafetyCorrectiveAction rdf:type owl:Class ;
                             rdfs:subClassOf :MedicalEntity ;
                             rdfs:comment "An action taken by a manufacturer to reduce a risk of death or serious deterioration associated with the use of a device already placed on the market (FSCA)."@en ;
                             rdfs:label "Field Safety Corrective Action"@en .


###  http://www.example.org/emdco#IVDRRiskClass
:IVDRRiskClass rdf:type owl:Class ;
               rdfs:subClassOf :RiskClass ;
               rdfs:comment "Risk classification under Regulation EU 2017/746 (IVDR): Class A, B, C, D."@en ;
               rdfs:label "IVDR Risk Class"@en .


###  http://www.example.org/emdco#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :Device ;
                   rdfs:comment "A device intended to be totally or partially introduced into the human body and intended to remain there after the procedure."@en ;
                   rdfs:label "Implantable Device"@en .


###  http://www.example.org/emdco#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :FieldSafetyCorrectiveAction ;
                  rdfs:comment "A corrective action performed on a device while it remains in use, such as software updates or protocol changes."@en ;
                  rdfs:label "In Situ Correction"@en .


###  http://www.example.org/emdco#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device ;
                         rdfs:comment "A device intended for examination of specimens derived from the human body, regulated under IVDR (EU 2017/746)."@en ;
                         rdfs:label "In Vitro Diagnostic Device"@en .


###  http://www.example.org/emdco#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :MedicalEntity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :involvedDevice ;
                            owl:someValuesFrom :Device
                          ] ;
          rdfs:comment "A malfunction or deterioration in the characteristics of a device which has led or could lead to the death or serious injury of a patient."@en ;
          rdfs:label "Incident"@en .


###  http://www.example.org/emdco#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk of device-related infection including site infection, sepsis or biofilm formation."@en ;
               rdfs:label "Infection Risk"@en .


###  http://www.example.org/emdco#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "Risk of direct physical harm or injury to the patient caused by the device."@en ;
            rdfs:label "Injury Risk"@en .


###  http://www.example.org/emdco#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :Risk ;
                  rdfs:comment "Risk from electromagnetic interference or MRI-related artefacts affecting device performance."@en ;
                  rdfs:label "Interference Risk"@en .


###  http://www.example.org/emdco#MDRRiskClass
:MDRRiskClass rdf:type owl:Class ;
              rdfs:subClassOf :RiskClass ;
              rdfs:comment "Risk classification under Regulation EU 2017/745 (MDR): Class I, IIa, IIb, III."@en ;
              rdfs:label "MDR Risk Class"@en .


###  http://www.example.org/emdco#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Risk arising from device malfunction or failure to perform as intended."@en ;
                 rdfs:label "Malfunction Risk"@en .


###  http://www.example.org/emdco#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf :MedicalEntity ;
              rdfs:comment "A natural or legal person who manufactures or fully refurbishes a device or has a device designed, manufactured or fully refurbished."@en ;
              rdfs:label "Manufacturer"@en .


###  http://www.example.org/emdco#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk from wear debris, corrosion or adverse tissue reaction to implant materials."@en ;
              rdfs:label "Material Risk"@en .


###  http://www.example.org/emdco#MedicalEntity
:MedicalEntity rdf:type owl:Class ;
               rdfs:comment "Top-level class for all entities in the medical device domain."@en ;
               rdfs:label "Medical Entity"@en .


###  http://www.example.org/emdco#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  rdfs:comment "An incident where a potential harm did not reach the patient due to fortunate circumstances or corrective action."@en ;
                  rdfs:label "Near Miss Incident"@en .


###  http://www.example.org/emdco#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk of unintended ionising or non-ionising radiation exposure."@en ;
               rdfs:label "Radiation Risk"@en .


###  http://www.example.org/emdco#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :FieldSafetyCorrectiveAction ;
        rdfs:comment "A corrective action to return or replace devices already distributed due to a safety issue."@en ;
        rdfs:label "Recall"@en .


###  http://www.example.org/emdco#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf :MedicalEntity ;
      rdfs:comment "An identified risk associated with a medical device, classified according to IMDRF nomenclature."@en ;
      rdfs:label "Risk"@en .


###  http://www.example.org/emdco#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "Classification of medical device risk level as defined by MDR or IVDR."@en ;
           rdfs:label "Risk Class"@en .


###  http://www.example.org/emdco#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :FieldSafetyCorrectiveAction ;
             rdfs:comment "A communication issued to healthcare professionals or users regarding updated safety guidance for a device."@en ;
             rdfs:label "Safety Alert"@en .


###  http://www.example.org/emdco#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :InVitroDiagnosticDevice ;
                rdfs:comment "An IVD device intended for use by lay persons in a home environment."@en ;
                rdfs:label "Self-Test Device"@en .


###  http://www.example.org/emdco#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "An incident that directly or indirectly led to the death, serious injury, or serious deterioration in the health of a patient."@en ;
                 rdfs:label "Serious Incident"@en .


###  http://www.example.org/emdco#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :Device ;
                 rdfs:comment "A device intended to be used on one individual during a single procedure."@en ;
                 rdfs:label "Single Use Device"@en .


###  http://www.example.org/emdco#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk arising from software malfunction including incorrect dosing or alarming."@en ;
              rdfs:label "Software Risk"@en .


###  http://www.example.org/emdco#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :FieldSafetyCorrectiveAction ;
            rdfs:comment "A field safety notice issued to device users or operators providing updated usage instructions."@en ;
            rdfs:label "User Notice"@en .


#################################################################
#    Individuals
#################################################################

###  http://www.example.org/emdco#abbott
:abbott rdf:type owl:NamedIndividual ,
                 :Manufacturer ;
        :authorizationNumber "DE/2017/005678" ;
        :country "Germany" ;
        :eudameSRN "SRN-DE-MED-0002" ;
        :manufacturerID "MAN-002" ;
        :manufacturerName "Abbott Medical Devices" ;
        rdfs:comment "German-registered manufacturer of cardiovascular and diagnostic devices."@en ;
        rdfs:label "Abbott Medical Devices"@en .


###  http://www.example.org/emdco#bostonScientific
:bostonScientific rdf:type owl:NamedIndividual ,
                           :Manufacturer ;
                  :authorizationNumber "IE/2017/002345" ;
                  :country "Ireland" ;
                  :eudameSRN "SRN-IE-MED-0006" ;
                  :manufacturerID "MAN-006" ;
                  :manufacturerName "Boston Scientific Corporation" ;
                  rdfs:comment "Irish-registered manufacturer of interventional cardiology and electrophysiology devices."@en ;
                  rdfs:label "Boston Scientific Corporation"@en .


###  http://www.example.org/emdco#classA
:classA rdf:type owl:NamedIndividual ,
                 :IVDRRiskClass ;
        rdfs:comment "Lowest risk class under IVDR (EU 2017/746)."@en ;
        rdfs:label "Class A"@en .


###  http://www.example.org/emdco#classB
:classB rdf:type owl:NamedIndividual ,
                 :IVDRRiskClass ;
