#################################################################
#    Annotations
#################################################################

:rule1 swrl:body [ ] ;
swrl:head [ ] .


#################################################################
#    Rules
#################################################################

<urn:swrl:var#f> rdf:type swrl:Variable .

<urn:swrl:var#i> rdf:type swrl:Variable .

<urn:swrl:var#d> rdf:type swrl:Variable .

<urn:swrl:var#m> rdf:type swrl:Variable .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:BuiltinAtom ;
                           swrl:builtin :FieldSafetyCorrectiveAction ;
                           swrl:arguments ( <urn:swrl:var#f>
                                          )
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:BuiltinAtom ;
                                      swrl:builtin :addressesIncident ;
                                      swrl:arguments ( <urn:swrl:var#f>
                                                       <urn:swrl:var#i>
                                                     )
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:BuiltinAtom ;
                                                 swrl:builtin :involvedDevice ;
                                                 swrl:arguments ( <urn:swrl:var#i>
                                                                  <urn:swrl:var#d>
                                                                )
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:BuiltinAtom ;
                                                            swrl:builtin :hasManufacturer ;
                                                            swrl:arguments ( <urn:swrl:var#d>
                                                                             <urn:swrl:var#m>
                                                                           )
                                                          ] ;
                                                rdf:rest rdf:nil
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:BuiltinAtom ;
                           swrl:builtin :issuedBy ;
                           swrl:arguments ( <urn:swrl:var#f>
                                            <urn:swrl:var#m>
                                          )
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:BuiltinAtom ;
                           swrl:builtin :SeriousIncident ;
                           swrl:arguments ( <urn:swrl:var#i>
                                          )
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:BuiltinAtom ;
                                      swrl:builtin :involvedDevice ;
                                      swrl:arguments ( <urn:swrl:var#i>
                                                       <urn:swrl:var#d>
                                                     )
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:BuiltinAtom ;
                                                 swrl:builtin :hasManufacturer ;
                                                 swrl:arguments ( <urn:swrl:var#d>
                                                                  <urn:swrl:var#m>
                                                                )
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:BuiltinAtom ;
                           swrl:builtin :reportedBy ;
                           swrl:arguments ( <urn:swrl:var#i>
                                            <urn:swrl:var#m>
                                          )
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

