    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classA -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classA">
        <rdf:type rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Lowest risk class under IVDR (EU 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">Class A</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classB -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classB">
        <rdf:type rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Low-medium risk class under IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Class B</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classC -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classC">
        <rdf:type rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Medium-high risk class under IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Class C</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classD -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classD">
        <rdf:type rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Highest risk class under IVDR. Used for HIV, hepatitis and blood group tests.</rdfs:comment>
        <rdfs:label xml:lang="en">Class D</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classI -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classI">
        <rdf:type rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <rdfs:comment xml:lang="en">Lowest risk class under MDR (EU 2017/745). General controls required.</rdfs:comment>
        <rdfs:label xml:lang="en">Class I</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classIII -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classIII">
        <rdf:type rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <isSubclassifiedUnder rdf:resource="http://www.example.org/emdco#classIIb"/>
        <rdfs:comment xml:lang="en">Highest risk class under MDR. Reserved for devices posing the highest risk, requires clinical evaluation.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classIIa -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classIIa">
        <rdf:type rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <isSubclassifiedUnder rdf:resource="http://www.example.org/emdco#classI"/>
        <rdfs:comment xml:lang="en">Medium risk class under MDR. Requires involvement of a notified body.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#classIIb -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#classIIb">
        <rdf:type rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <isSubclassifiedUnder rdf:resource="http://www.example.org/emdco#classIIa"/>
        <rdfs:comment xml:lang="en">Medium-high risk class under MDR. Requires stricter notified body scrutiny.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#cobasSARSCoV2 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#cobasSARSCoV2">
        <rdf:type rdf:resource="http://www.example.org/emdco#InVitroDiagnosticDevice"/>
