<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/emdco#"
     xml:base="http://www.example.org/emdco"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:emdco="http://www.example.org/emdco#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://www.example.org/emdco">
        <dc:creator xml:lang="en">Harmanjeet Singh Kaur</dc:creator>
        <dc:description xml:lang="en">This ontology models the EUDAMED catalogue including devices, manufacturers, identified risks, incidents and field safety corrective actions (FSCA).</dc:description>
        <dc:title xml:lang="en">European Medical Device Catalogue Ontology (EMDCO)</dc:title>
        <rdfs:comment xml:lang="en">Ontology for the European catalogue of high-risk medical devices under MDR (EU 2017/745) and IVDR (EU 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">European Medical Device Catalogue Ontology</rdfs:label>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument1 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument1"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument2 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument2"/>
    


    <!-- http://www.w3.org/2003/11/swrl#body -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#body"/>
    


    <!-- http://www.w3.org/2003/11/swrl#classPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#classPredicate"/>
    


    <!-- http://www.w3.org/2003/11/swrl#head -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#head"/>
    


    <!-- http://www.w3.org/2003/11/swrl#propertyPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#propertyPredicate"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdco#addressesIncident -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#addressesIncident">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to the incident that triggered it.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#affectsDeviceType">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:comment xml:lang="en">Relates a risk to the type of device it primarily affects.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#associatedRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#associatedRisk">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the identified risk category according to IMDRF nomenclature.</rdfs:comment>
        <rdfs:label xml:lang="en">associated risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasManufacturer">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a device to its registered manufacturer in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <rdfs:comment xml:lang="en">Relates a device to its regulatory risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#involvedDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#involvedDevice">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:comment xml:lang="en">Relates an incident to the specific device involved in the event.</rdfs:comment>
        <rdfs:label xml:lang="en">involved device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#isSubclassifiedUnder -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#isSubclassifiedUnder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <rdfs:comment xml:lang="en">Transitive property relating a risk class to a higher-level risk class in the MDR/IVDR classification hierarchy.</rdfs:comment>
        <rdfs:label xml:lang="en">is subclassified under</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#issuedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#issuedBy">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to the manufacturer who issued it.</rdfs:comment>
        <rdfs:label xml:lang="en">issued by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#reportedBy">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates an incident to the manufacturer who submitted the report to EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdco#actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#actionDate">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#authorizationNumber">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The national authorization number issued by the competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#country -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#country">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The country where the manufacturer is legally registered.</rdfs:comment>
        <rdfs:label xml:lang="en">country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#countryReported -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#countryReported">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The EU member state where the incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#deviceID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#deviceID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier for the device in the EUDAMED catalogue.</rdfs:comment>
        <rdfs:label xml:lang="en">device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#deviceName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The commercial or trade name of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#devicesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The number of devices covered by the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#eudameSRN -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#eudameSRN">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Single Registration Number assigned by EUDAMED to the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#eudamedFscaRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#eudamedFscaRef">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official EUDAMED reference number for the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#eudamedIncidentRef">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official EUDAMED reference number for the incident report.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#fscaID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#fscaID">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier for the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#imdrfCode">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The standardised IMDRF (International Medical Device Regulators Forum) nomenclature code for the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#incidentID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#incidentID">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier for the incident in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">incident ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#intendedPurpose">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The intended use of the device as declared by the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isActive">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device operation depends on an external energy source.</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isIVD -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isIVD">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is an in vitro diagnostic device regulated under IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isImplantable">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is intended to be implanted in the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isReusable">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device can be reused after appropriate reprocessing.</rdfs:comment>
        <rdfs:label xml:lang="en">is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#manufacturerID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#manufacturerID">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique manufacturer identifier in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">manufacturer ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#manufacturerName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#manufacturerName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The registered legal name of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">manufacturer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#outcome -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#outcome">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The clinical outcome of the incident for the patient or user.</rdfs:comment>
        <rdfs:label xml:lang="en">outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#patientAge -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#patientAge">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Age of the patient involved in the incident at the time of the event.</rdfs:comment>
        <rdfs:label xml:lang="en">patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#probability -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#probability">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The estimated probability of occurrence of the risk: Low, Medium or High.</rdfs:comment>
        <rdfs:label xml:lang="en">probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#regulatoryFramework -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#regulatoryFramework">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The EU regulation applicable to the device: MDR or IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">regulatory framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#reportDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#reportDate">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the incident was officially reported to EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#riskName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#riskName">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The descriptive name of the identified risk.</rdfs:comment>
        <rdfs:label xml:lang="en">risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#severity -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#severity">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The clinical severity of the risk: Critical, Serious, Moderate or Low.</rdfs:comment>
        <rdfs:label xml:lang="en">severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#status -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#status">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The current status of the corrective action: Open or Closed.</rdfs:comment>
        <rdfs:label xml:lang="en">status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#udiDI -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#udiDI">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique Device Identifier - Device Identifier as registered in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdco#ActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:comment xml:lang="en">A medical device whose operation depends on a source of energy other than that generated by the human body or gravity.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ActiveImplantDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#ActiveImplantDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ImplantableDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdco#isActive"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdco#isImplantable"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A device that is both active and implantable, such as pacemakers or ventricular assist devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ContaminationRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk from reagent or product contamination leading to systematic errors.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk from exploitable software vulnerabilities enabling unauthorised device access.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Device -->


    <owl:Class rdf:about="http://www.example.org/emdco#Device">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdco#hasManufacturer"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device as defined by MDR (EU 2017/745) or IVDR (EU 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk of diagnostic error including false positive or false negative results from IVD devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#FieldSafetyCorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/emdco#FieldSafetyCorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalEntity"/>
        <rdfs:comment xml:lang="en">An action taken by a manufacturer to reduce a risk of death or serious deterioration associated with the use of a device already placed on the market (FSCA).</rdfs:comment>
        <rdfs:label xml:lang="en">Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#IVDRRiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdco#IVDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <rdfs:comment xml:lang="en">Risk classification under Regulation EU 2017/746 (IVDR): Class A, B, C, D.</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ImplantableDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:comment xml:lang="en">A device intended to be totally or partially introduced into the human body and intended to remain there after the procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#InSituCorrection -->


    <owl:Class rdf:about="http://www.example.org/emdco#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A corrective action performed on a device while it remains in use, such as software updates or protocol changes.</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:comment xml:lang="en">A device intended for examination of specimens derived from the human body, regulated under IVDR (EU 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Incident -->


    <owl:Class rdf:about="http://www.example.org/emdco#Incident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdco#involvedDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.example.org/emdco#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A malfunction or deterioration in the characteristics of a device which has led or could lead to the death or serious injury of a patient.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#InfectionRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk of device-related infection including site infection, sepsis or biofilm formation.</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#InjuryRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk of direct physical harm or injury to the patient caused by the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#InterferenceRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk from electromagnetic interference or MRI-related artefacts affecting device performance.</rdfs:comment>
        <rdfs:label xml:lang="en">Interference Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#MDRRiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdco#MDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <rdfs:comment xml:lang="en">Risk classification under Regulation EU 2017/745 (MDR): Class I, IIa, IIb, III.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#MalfunctionRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk arising from device malfunction or failure to perform as intended.</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Manufacturer -->


    <owl:Class rdf:about="http://www.example.org/emdco#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A natural or legal person who manufactures or fully refurbishes a device or has a device designed, manufactured or fully refurbished.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#MaterialRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk from wear debris, corrosion or adverse tissue reaction to implant materials.</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#MedicalEntity -->


    <owl:Class rdf:about="http://www.example.org/emdco#MedicalEntity">
        <rdfs:comment xml:lang="en">Top-level class for all entities in the medical device domain.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#NearMissIncident -->


    <owl:Class rdf:about="http://www.example.org/emdco#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:comment xml:lang="en">An incident where a potential harm did not reach the patient due to fortunate circumstances or corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">Near Miss Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#RadiationRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk of unintended ionising or non-ionising radiation exposure.</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Recall -->


    <owl:Class rdf:about="http://www.example.org/emdco#Recall">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A corrective action to return or replace devices already distributed due to a safety issue.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Risk -->


    <owl:Class rdf:about="http://www.example.org/emdco#Risk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalEntity"/>
        <rdfs:comment xml:lang="en">An identified risk associated with a medical device, classified according to IMDRF nomenclature.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#RiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdco#RiskClass">
        <rdfs:comment xml:lang="en">Classification of medical device risk level as defined by MDR or IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SafetyAlert -->


    <owl:Class rdf:about="http://www.example.org/emdco#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A communication issued to healthcare professionals or users regarding updated safety guidance for a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SelfTestDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">An IVD device intended for use by lay persons in a home environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Self-Test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SeriousIncident -->


    <owl:Class rdf:about="http://www.example.org/emdco#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:comment xml:lang="en">An incident that directly or indirectly led to the death, serious injury, or serious deterioration in the health of a patient.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SingleUseDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Device"/>
        <rdfs:comment xml:lang="en">A device intended to be used on one individual during a single procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Single Use Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SoftwareRisk -->


    <owl:Class rdf:about="http://www.example.org/emdco#SoftwareRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment xml:lang="en">Risk arising from software malfunction including incorrect dosing or alarming.</rdfs:comment>
        <rdfs:label xml:lang="en">Software Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#UserNotice -->


    <owl:Class rdf:about="http://www.example.org/emdco#UserNotice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A field safety notice issued to device users or operators providing updated usage instructions.</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


