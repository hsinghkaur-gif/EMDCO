        <addressesIncident rdf:resource="http://www.example.org/emdco#inc001"/>
        <issuedBy rdf:resource="http://www.example.org/emdco#medtronic"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-01</actionDate>
