<http://www.example.org/emdco#manufacturerName> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Manufacturer> .
<http://www.example.org/emdco#manufacturerName> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#string> .
<http://www.example.org/emdco#manufacturerName> <http://www.w3.org/2000/01/rdf-schema#comment> "The registered legal name of the manufacturer."@en .
<http://www.example.org/emdco#manufacturerName> <http://www.w3.org/2000/01/rdf-schema#label> "manufacturer name"@en .
# 
# http://www.example.org/emdco#outcome
<http://www.example.org/emdco#outcome> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<http://www.example.org/emdco#outcome> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Incident> .
<http://www.example.org/emdco#outcome> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#string> .
<http://www.example.org/emdco#outcome> <http://www.w3.org/2000/01/rdf-schema#comment> "The clinical outcome of the incident for the patient or user."@en .
<http://www.example.org/emdco#outcome> <http://www.w3.org/2000/01/rdf-schema#label> "outcome"@en .
# 
# http://www.example.org/emdco#patientAge
<http://www.example.org/emdco#patientAge> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<http://www.example.org/emdco#patientAge> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Incident> .
<http://www.example.org/emdco#patientAge> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#integer> .
<http://www.example.org/emdco#patientAge> <http://www.w3.org/2000/01/rdf-schema#comment> "Age of the patient involved in the incident at the time of the event."@en .
<http://www.example.org/emdco#patientAge> <http://www.w3.org/2000/01/rdf-schema#label> "patient age"@en .
# 
# http://www.example.org/emdco#probability
<http://www.example.org/emdco#probability> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<http://www.example.org/emdco#probability> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Risk> .
<http://www.example.org/emdco#probability> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#string> .
<http://www.example.org/emdco#probability> <http://www.w3.org/2000/01/rdf-schema#comment> "The estimated probability of occurrence of the risk: Low, Medium or High."@en .
<http://www.example.org/emdco#probability> <http://www.w3.org/2000/01/rdf-schema#label> "probability"@en .
# 
# http://www.example.org/emdco#regulatoryFramework
<http://www.example.org/emdco#regulatoryFramework> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<http://www.example.org/emdco#regulatoryFramework> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Device> .
<http://www.example.org/emdco#regulatoryFramework> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#string> .
<http://www.example.org/emdco#regulatoryFramework> <http://www.w3.org/2000/01/rdf-schema#comment> "The EU regulation applicable to the device: MDR or IVDR."@en .
<http://www.example.org/emdco#regulatoryFramework> <http://www.w3.org/2000/01/rdf-schema#label> "regulatory framework"@en .
# 
# http://www.example.org/emdco#reportDate
<http://www.example.org/emdco#reportDate> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<http://www.example.org/emdco#reportDate> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Incident> .
<http://www.example.org/emdco#reportDate> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#date> .
<http://www.example.org/emdco#reportDate> <http://www.w3.org/2000/01/rdf-schema#comment> "The date on which the incident was officially reported to EUDAMED."@en .
<http://www.example.org/emdco#reportDate> <http://www.w3.org/2000/01/rdf-schema#label> "report date"@en .
# 
# http://www.example.org/emdco#riskName
<http://www.example.org/emdco#riskName> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<http://www.example.org/emdco#riskName> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Risk> .
<http://www.example.org/emdco#riskName> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#string> .
<http://www.example.org/emdco#riskName> <http://www.w3.org/2000/01/rdf-schema#comment> "The descriptive name of the identified risk."@en .
<http://www.example.org/emdco#riskName> <http://www.w3.org/2000/01/rdf-schema#label> "risk name"@en .
# 
# http://www.example.org/emdco#severity
<http://www.example.org/emdco#severity> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<http://www.example.org/emdco#severity> <http://www.w3.org/2000/01/rdf-schema#domain> <http://www.example.org/emdco#Risk> .
<http://www.example.org/emdco#severity> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#string> .
